# ============================================================
# Inventory & Order Management System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=inventory_db

# ----------------------------------------------------------
# Backend
# ----------------------------------------------------------
# Full SQLAlchemy connection URL (auto-built from above in docker-compose,
# but set explicitly here for non-Docker local dev)
DATABASE_URL=postgresql://inventory_user:changeme_strong_password@localhost:5432/inventory_db

# Application environment: development | production
APP_ENV=production

# Secret key for signing tokens / sessions — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_secure_random_hex_string

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost,http://localhost:80,https://yourdomain.com

# ----------------------------------------------------------
# Frontend (Vite build-time variable)
# ----------------------------------------------------------
# In Docker Compose, the frontend calls the backend through Nginx proxy at /api/.
# For local Vite dev server, point directly to the backend.
VITE_API_URL=http://localhost:8000

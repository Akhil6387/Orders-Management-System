# Backend-specific environment variables
# Used when running the backend directly (without Docker Compose)

DATABASE_URL=postgresql://inventory_user:changeme_strong_password@localhost:5432/inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=inventory_db

APP_ENV=development
SECRET_KEY=replace_with_a_secure_random_hex_string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
